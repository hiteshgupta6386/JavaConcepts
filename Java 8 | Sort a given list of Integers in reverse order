Write a Java 8 program to sort a given list of decimal numbers in reverse order.

import java.util.Arrays;
import java.util.List;
import java.util.stream.Collectors;

public class ReverseSortedList {
    public static void main(String[] args){
        List<Integer> unsortedNum = Arrays.asList(2, 5, 7, 1, 2, 9, 4, 1);

        List<Integer> sortedNum = unsortedNum.stream().sorted( (x, y) -> Integer.compare(y, x)).collect(Collectors.toList());

        System.out.println(sortedNum);

    }
}


