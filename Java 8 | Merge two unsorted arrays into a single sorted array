Write a Java 8 program to merge two unsorted arrays into a single sorted array using the stream API.

import java.util.Arrays;
import java.util.stream.IntStream;

public class MergeArraysIntoSorted {
    public static void main(String[] args){
        int[] array1 = {1, 2, 4, 8, 3};
        int[] array2 = {5, 9, 2, 6, 3};

        int[] mergedSortedArray = IntStream.concat(Arrays.stream(array1), Arrays.stream(array2)).sorted().toArray();

        System.out.println(Arrays.toString(mergedSortedArray));

    }
}


